<Window x:Class="PROG6221.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Chat" Height="450" Width="600"
        Background="#2C003E" Foreground="White">
	<Grid Margin="10">

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Title -->
		<TextBlock Grid.Row="0"
				   Text="Cybersecurity Awareness Bot"
				   FontSize="18"
				   FontWeight="Bold"
				   HorizontalAlignment="Center"
				   Margin="0,0,0,10"/>

		<!-- Chat Window -->
		<TextBox x:Name="txtChat"
				 Grid.Row="1"
				 IsReadOnly="True"
				 AcceptsReturn="True"
				 TextWrapping="Wrap"
				 VerticalScrollBarVisibility="Auto"
				 TextChanged="txtChat_TextChanged"/>

		<!-- User Input -->
		<TextBox x:Name="txtInput"
				 Grid.Row="2"
				 Margin="0,10,0,0"
				 TextChanged="txtInput_TextChanged"/>

		<!-- Buttons -->
		<StackPanel Grid.Row="3"
					Orientation="Horizontal"
					HorizontalAlignment="Center"
					Margin="0,10,0,0">

			<Button x:Name="btnSEND"
					Content="Send"
					Width="80"
					Margin="5"
					Click="btnSEND_Click"/>

			<Button x:Name="btnQuiz"
					Content="Start Quiz"
					Width="100"
					Margin="5"
					Click="btnQuiz_Click"/>

			<Button x:Name="btnActivityLog"
					Content="Activity Log"
					Width="100"
					Margin="5"
					Click="btnActivityLog_Click"/>

		</StackPanel>

	</Grid>
</Window>
